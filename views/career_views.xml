<odoo>
    <data>
        <!-- LIST y FORM de careers usando el modelo university.career -->
        <record id="view_career_list" model="ir.ui.view">
            <field name="name">career.list</field>
            <field name="model">university.career</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_career_form" model="ir.ui.view">
            <field name="name">career.form</field>
            <field name="model">university.career</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_careers" model="ir.actions.act_window">
            <field name="name">Careers</field>
            <field name="res_model">university.career</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>