<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- LIST -->
    <record id="view_professor_list" model="ir.ui.view">
        <field name="name">professor.list</field>
        <field name="model">university.professor</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="subjects_names"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_professor_form" model="ir.ui.view">
        <field name="name">professor.form</field>
        <field name="model">university.professor</field>
        <field name="arch" type="xml">

            <form>
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                    </group>

                </sheet>
            </form>

        </field>
    </record>

    <!-- ACTION -->
    <record id="action_professors" model="ir.actions.act_window">
        <field name="name">Professors</field>
        <field name="res_model">university.professor</field>
        <field name="view_mode">list,form</field>
    </record>

</data>
</odoo>