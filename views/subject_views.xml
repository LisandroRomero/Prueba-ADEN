<odoo>
    <data>
        <record id="view_subject_list" model="ir.ui.view">
            <field name="name">subject.list</field>
            <field name="model">university.subject</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                        <field name="student_count"/>
                        <field name="professor_id"/>
                        <field name="study_plan_id"/>
                        <field name="student_count"/>
                        <field name="max_capacity"/>
                </list>
            </field>
        </record>

        <record id="view_subject_form" model="ir.ui.view">
            <field name="name">subject.form</field>
            <field name="model">university.subject</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="student_count"/>
                            <field name="professor_id"/>
                            <field name="study_plan_id"/>
                            <field name="student_count"/>
                            <field name="max_capacity"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_subjects" model="ir.actions.act_window">
            <field name="name">Subjects</field>
            <field name="res_model">university.subject</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>